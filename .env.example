# =============================================================================
# ClassEdge Mobile - Environment Variables
# =============================================================================
# Local dev:
#   1. Copy this file to .env (or run `pnpm env:pull:dev` for the latest EAS values).
#   2. `EXPO_PUBLIC_*` vars are inlined into the JS bundle at build/start time —
#      do not put true secrets here. Treat as client-visible.
#
# EAS builds:
#   Each build profile in eas.json sets `environment` (development/preview/production).
#   EAS injects the matching Environment Variables from the Expo dashboard.
#   Manage them at https://expo.dev/accounts/<acct>/projects/classedge/environment-variables
#   or via `eas env:create` / `eas env:list`.
#
# Variant switching:
#   APP_VARIANT (development | preview | production) controls app name, iOS
#   bundle id, Android package, URL scheme, OneSignal mode, and aps-environment
#   in app.config.ts. eas.json sets it per build profile automatically; for local
#   dev use `pnpm start:dev | start:preview | start:prod`.
# =============================================================================

# API
EXPO_PUBLIC_API_URL=https://your-api-domain.com

# PowerSync
EXPO_PUBLIC_POWERSYNC_ENDPOINT=https://your-powersync-instance.powersync.journeyapps.com

# Storage Keys (used for secure token/session storage identifiers)
EXPO_PUBLIC_ACCESS_TOKEN_KEY=access_token
EXPO_PUBLIC_REFRESH_TOKEN_KEY=refresh_token
EXPO_PUBLIC_AUTH_USER_KEY=auth_user

# Microsoft OAuth
EXPO_PUBLIC_MICROSOFT_CLIENT_ID=your-microsoft-client-id
EXPO_PUBLIC_MICROSOFT_TENANT_ID=your-microsoft-tenant-id

# OneSignal Push Notifications
EXPO_PUBLIC_ONESIGNAL_APP_ID=<your-sandbox-onesignal-app-id>

# Sentry Error Tracking
EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn
