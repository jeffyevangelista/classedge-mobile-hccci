# =============================================================================
# ClassEdge Mobile - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for local development.
# For EAS builds, set these in the Expo dashboard under Environment Variables
# for each environment (development, preview, production).
# =============================================================================

# API
EXPO_PUBLIC_API_URL=https://your-api-domain.com

# PowerSync
EXPO_PUBLIC_POWERSYNC_ENDPOINT=https://your-powersync-instance.powersync.journeyapps.com

# Storage Keys (used for secure token/session storage identifiers)
EXPO_PUBLIC_ACCESS_TOKEN_KEY=access_token
EXPO_PUBLIC_REFRESH_TOKEN_KEY=refresh_token
EXPO_PUBLIC_AUTH_USER_KEY=auth_user

# Microsoft OAuth
EXPO_PUBLIC_MICROSOFT_CLIENT_ID=your-microsoft-client-id
EXPO_PUBLIC_MICROSOFT_TENANT_ID=your-microsoft-tenant-id

# OneSignal Push Notifications
EXPO_PUBLIC_ONESIGNAL_APP_ID=your-onesignal-app-id
