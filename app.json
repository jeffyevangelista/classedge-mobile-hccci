{
  "expo": {
    "name": "classedge",
    "slug": "classedge",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "classedge",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jeffigy.classedge",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ]
      },
      "entitlements": {
        "aps-environment": "development"
      },
      "icon": {
        "dark": "./assets/icons/ios/ios-dark.png",
        "light": "./assets/icons/ios/ios-light.png",
        "tinted": "./assets/icons/ios/ios-tinted.png"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/android/adaptive-icon.png",
        "backgroundImage": "./assets/icons/android/adaptive-icon.png",
        "monochromeImage": "./assets/icons/android/adaptive-icon.png",
        "backgroundColor": "#E6F4FE"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.jeffigy.classedge"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "onesignal-expo-plugin",
        {
          "mode": "development",
          "smallIcons": [
            "./assets/notifications/ic_stat_onesignal_default.png"
          ]
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icons/splash/splash-icon-light.png",
          "imageWidth": 170,
          "imageHeight": 170,
          "resizeMode": "contain",
          "backgroundColor": "#f9f9f9",
          "dark": {
            "image": "./assets/icons/splash/splash-icon-dark.png",
            "backgroundColor": "#1a1a1a"
          }
        }
      ],
      "expo-web-browser",
      "expo-background-task",
      "expo-video",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "onesignalAppId": "89c53280-0393-43c1-8416-6ae2f4771bdd"
    }
  }
}
